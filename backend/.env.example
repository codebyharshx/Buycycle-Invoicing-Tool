# Backend Environment Variables

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3007

# MySQL Database (Main)
MYSQL_HOST=your-mysql-host
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_PORT=3306

# MySQL Database (BLS Logistics)
BLS_DB_HOST=your-bls-host
BLS_DB_USER=your-bls-user
BLS_DB_PASSWORD=your-bls-password
BLS_DB_PORT=3306

# MySQL Database (Logs)
LOGS_DB_HOST=your-logs-host
LOGS_DB_USER=your-logs-user
LOGS_DB_PASSWORD=your-logs-password
LOGS_DB_PORT=3306

# PostgreSQL (Neon)
NEON_POSTGRES_URL=postgresql://user:password@host/database

# AI API Keys (for invoice OCR)
GEMINI_API_KEY=your-gemini-api-key
MISTRAL_API_KEY=your-mistral-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
REPLICATE_API_KEY=your-replicate-api-key

# AWS S3 (file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-s3-bucket
AWS_REGION=eu-central-1

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
